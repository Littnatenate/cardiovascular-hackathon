# API Keys
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# Backend Config
DATABASE_URL=sqlite:///./test.db
DEBUG=True

# Frontend Config
VITE_API_URL=http://localhost:8000

# ── MedSafe Security ──
# API Key required for all /api/ requests
MEDSAFE_API_KEY=medsafe-hackathon-2026

# ── Local AI Config (LM Studio) ──
# Set to 'http://127.0.0.1:1234/v1' for LM Studio Local Server
MEDSAFE_LLM_BASE_URL=http://127.0.0.1:1234/v1
MEDSAFE_LLM_API_KEY=lm-studio
MEDSAFE_LLM_MODEL="qwen/qwen3.5-9b"

# Hospital Wifi Simulation — comma-separated trusted IPs, or "*" to allow all
MEDSAFE_TRUSTED_IPS=*

# CORS — comma-separated frontend origins
MEDSAFE_CORS_ORIGINS=http://localhost:3000

# Rate Limiting
MEDSAFE_RATE_LIMIT=30
MEDSAFE_RATE_WINDOW=60
